# Cloudflare Workers Static Assets response headers.
# https://developers.cloudflare.com/workers/static-assets/headers/
#
# Cloudflare's default for every asset is `public, max-age=0, must-revalidate`,
# which forces the browser to revalidate every CSS/JS/font on every navigation.
# These rules override that for content-hashed assets so repeat loads and page-
# to-page navigation hit the disk cache instead of the network. HTML is left at
# the default (always revalidate) so a new deploy shows up immediately.

# Content-hashed build output — JS, CSS, and self-hosted fonts (/_astro/fonts/*).
# The hash changes whenever the content does, so these are safe to pin forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static images & icons live at stable (non-hashed) paths, so cache for a day
# and revalidate — long enough to help, short enough that updates propagate.
/brand/*
  Cache-Control: public, max-age=86400
/og/*
  Cache-Control: public, max-age=86400
/favicon.svg
  Cache-Control: public, max-age=86400

# Pagefind search index + runtime (mostly content-addressed fragments).
/pagefind/*
  Cache-Control: public, max-age=86400

# Per-version dashboard payloads — a published version's data is stable.
/data/*
  Cache-Control: public, max-age=86400
