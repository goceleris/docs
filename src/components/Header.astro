---
import ThemeToggle from "./ThemeToggle.astro";
import Logo from "./Logo.astro";

const path = Astro.url.pathname;
const isActive = (p: string) => path === p || path.startsWith(p + "/");
const links = [
  { href: "/docs", label: "Docs" },
  { href: "/benchmarks", label: "Benchmarks" },
  { href: "/methodology", label: "Methodology" },
];
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand" aria-label="Celeris home">
      <Logo />
      <span class="brand-name">celeris</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        links.map((l) => (
          <a href={l.href} class:list={["nav-link", { active: isActive(l.href) }]}>
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="actions">
      <a
        class="ghost-btn"
        href="https://github.com/goceleris/celeris"
        target="_blank"
        rel="noopener"
        aria-label="Celeris on GitHub"
      >
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--header-h);
    backdrop-filter: blur(12px) saturate(1.4);
    background: color-mix(in oklch, var(--canvas) 78%, transparent);
    border-bottom: 1px solid var(--border);
  }
  .bar {
    height: 100%;
    display: flex;
    align-items: center;
    gap: var(--sp-5);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-weight: var(--fw-bold);
    letter-spacing: -0.03em;
  }
  .brand-name {
    font-size: var(--fs-md);
  }
  .nav {
    display: flex;
    gap: var(--sp-2);
    margin-inline-start: var(--sp-3);
  }
  .nav-link {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--r-sm);
    color: var(--text-muted);
    font-weight: var(--fw-medium);
    transition: color var(--dur-1), background var(--dur-1);
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--surface-2);
  }
  .nav-link.active {
    color: var(--accent-bright);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    margin-inline-start: auto;
  }
  .ghost-btn {
    display: inline-grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: var(--r-sm);
    color: var(--text-muted);
    transition: color var(--dur-1), background var(--dur-1);
  }
  .ghost-btn:hover {
    color: var(--text);
    background: var(--surface-2);
  }
  @media (max-width: 640px) {
    .nav {
      display: none;
    }
  }
</style>
