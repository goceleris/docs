---
import { Code } from "astro:components";

interface Props {
  code: string;
  lang?: string;
  /** Filename shown on the editor tab. */
  file?: string;
}
const { code, lang = "go", file = "main.go" } = Astro.props;
---

<figure class="cw">
  <div class="cw-head">
    <span class="cw-dots" aria-hidden="true"><i></i><i></i><i></i></span>
    <span class="cw-file"><i class="cw-ft" aria-hidden="true"></i>{file}</span>
  </div>
  <div class="cw-code">
    <Code code={code} lang={lang} theme="github-dark-default" />
  </div>
</figure>

<style>
  .cw {
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    background: oklch(0.13 0.012 256);
    box-shadow: var(--edge-highlight), var(--shadow-3);
  }
  .cw-head {
    display: flex;
    align-items: stretch;
    gap: var(--sp-3);
    height: 42px;
    padding-left: var(--sp-4);
    background: var(--surface-1);
    border-bottom: 1px solid var(--border);
  }
  .cw-dots {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .cw-dots i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--surface-3);
    box-shadow: inset 0 0 0 1px oklch(1 0 0 / 0.05);
  }
  /* the filename "tab" — connected to the code body via the accent top edge */
  .cw-file {
    align-self: flex-end;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: calc(100% - 7px);
    padding: 0 var(--sp-4);
    background: oklch(0.13 0.012 256);
    border: 1px solid var(--border);
    border-bottom: none;
    border-radius: var(--r-sm) var(--r-sm) 0 0;
    margin-bottom: -1px;
    box-shadow: inset 0 2px 0 var(--accent);
    font-family: var(--font-mono);
    font-size: var(--fs-2xs);
    color: var(--text);
  }
  .cw-ft {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--accent-2);
    flex: none;
  }

  /* code body + line numbers */
  .cw-code :global(pre.astro-code) {
    margin: 0;
    border: 0;
    border-radius: 0;
    padding: var(--sp-4) var(--sp-4) var(--sp-4) 0;
    counter-reset: ln;
  }
  .cw-code :global(pre.astro-code code) {
    display: inline-block;
    min-width: 100%;
  }
  .cw-code :global(.line) {
    counter-increment: ln;
  }
  .cw-code :global(.line)::before {
    content: counter(ln);
    display: inline-block;
    width: 2.6rem;
    margin-right: 1.15rem;
    padding-right: 0.5rem;
    text-align: right;
    color: var(--text-faint);
    opacity: 0.5;
    user-select: none;
  }
  .cw-code :global(.line:last-child:empty)::before {
    content: "";
  }
</style>
