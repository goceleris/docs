---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GroupIcon from "../../components/docs/GroupIcon.astro";

type Doc = CollectionEntry<"docs">;

const GROUP_ORDER = [
  "Getting Started",
  "Routing & Handlers",
  "Middleware",
  "Real-Time",
  "Data & Integration",
  "Reference",
  "Operations",
];

const BLURB: Record<string, string> = {
  "Getting Started": "Install Celeris, learn the mental model, and serve your first request.",
  "Routing & Handlers": "Routes and params, reading requests, binding, responses, errors, and files.",
  Middleware: "The chain and ordering, plus the in-tree catalog — security, auth, traffic, content.",
  "Real-Time": "Incremental streaming, Server-Sent Events, and WebSocket fan-out.",
  "Data & Integration": "Database & cache drivers on the event loop, and net/http interop.",
  Reference: "Every Config field, the four I/O engines, and the full Context API.",
  Operations: "Deploy behind TLS, shut down cleanly, observe, tune for load, and test.",
};

const all: Doc[] = (await getCollection("docs")).filter((d: Doc) => !d.data.draft);
const groups = GROUP_ORDER.map((name) => ({
  name,
  pages: all
    .filter((d: Doc) => d.data.group === name)
    .sort((a: Doc, b: Doc) => a.data.order - b.data.order),
})).filter((g) => g.pages.length > 0);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Celeris documentation",
  description: "User documentation for the Celeris Go HTTP engine.",
};
---

<BaseLayout
  title="Documentation · Celeris"
  description="User documentation for Celeris — the high-performance Go HTTP engine. Routing, middleware, real-time streaming, engines, deployment, and the full reference."
  jsonLd={jsonLd}
>
  <main id="main" tabindex="-1" class="container hub">
    <header class="hub-hero">
      <p class="hub-eyebrow">Documentation</p>
      <h1>Build high-performance services with <span class="grad">Celeris</span></h1>
      <p class="hub-lede">
        Everything you need to ship — from your first route to surviving extreme load.
        Every page is grounded in the real API, with runnable Go examples.
      </p>
      <div class="hub-cta">
        <a class="hbtn primary" href="/docs/getting-started">Get started →</a>
        <a class="hbtn ghost" href="/docs/core-concepts">Core concepts</a>
        <a class="hbtn ghost" href="/benchmarks">Benchmarks</a>
      </div>
    </header>

    <div class="hub-grid">
      {
        groups.map((g) => (
          <section class="hub-card">
            <div class="hub-card-head">
              <span class="hub-ico"><GroupIcon group={g.name} size={20} /></span>
              <h2><a class="hub-card-go" href={`/docs/${g.pages[0].id}`}>{g.name}</a></h2>
            </div>
            <p class="hub-blurb">{BLURB[g.name]}</p>
            <ul class="hub-links">
              {g.pages.map((p) => (
                <li>
                  <a href={`/docs/${p.id}`}>{p.data.title}</a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </main>
</BaseLayout>

<style>
  .hub {
    padding-block: clamp(2.5rem, 6vw, 4.5rem) var(--sp-9);
  }
  .hub-hero {
    max-width: 60ch;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .hub-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--text-faint);
    margin-bottom: var(--sp-3);
  }
  .hub-hero h1 {
    font-size: var(--h1);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-head);
    line-height: 1.1;
    font-optical-sizing: auto;
    margin-bottom: var(--sp-3);
  }
  .grad {
    background: linear-gradient(100deg, var(--accent-bright), var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-right: 0.08em;
    margin-right: -0.06em;
  }
  .hub-lede {
    font-size: var(--fs-md);
    color: var(--text-muted);
    line-height: var(--lh-snug);
  }
  .hub-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-5);
  }
  .hbtn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.1rem;
    border-radius: var(--r-md);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    transition: transform var(--dur-1), box-shadow var(--dur-1), border-color var(--dur-1), color var(--dur-1),
      filter var(--dur-1);
  }
  .hbtn.primary {
    border: 0;
    color: var(--text-on-accent);
    background: linear-gradient(180deg, var(--accent-bright), var(--accent));
    box-shadow:
      inset 0 1px 0 oklch(1 0 0 / 0.45),
      inset 0 -1px 0 oklch(0 0 0 / 0.18),
      0 1px 2px oklch(0 0 0 / 0.35),
      0 4px 16px var(--accent-glow);
  }
  .hbtn.primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }
  .hbtn.ghost {
    color: var(--text);
    background: var(--surface-1);
    border: 1px solid var(--border-strong);
  }
  .hbtn.ghost:hover {
    border-color: var(--accent);
    color: var(--accent-bright);
  }
  .hbtn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--canvas), 0 0 0 4px var(--accent-bright);
  }
  @media (prefers-reduced-motion: reduce) {
    .hbtn,
    .hbtn.primary:hover {
      transition: none;
      transform: none;
    }
  }

  .hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    gap: var(--sp-4);
  }
  .hub-card {
    position: relative;
    isolation: isolate;
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-1) 64%);
    box-shadow: var(--edge-highlight), var(--shadow-3);
    padding: var(--sp-5);
    cursor: pointer;
    user-select: none;
    transition: transform var(--dur-2) var(--ease);
  }
  /* Whole-card link → first page of the chapter (stretched-link pattern).
     Sits above the passive content but below the per-page links. */
  .hub-card-go {
    color: inherit;
  }
  .hub-card-go::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 3;
    border-radius: inherit;
  }
  .hub-card:hover .hub-card-go {
    color: var(--accent-bright);
  }
  @supports ((-webkit-mask-composite: xor) or (mask-composite: exclude)) {
    .hub-card {
      border-color: transparent;
    }
    .hub-card::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      border-radius: inherit;
      padding: 1px;
      pointer-events: none;
      background: var(--card-edge);
      -webkit-mask:
        linear-gradient(#000 0 0) content-box,
        linear-gradient(#000 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      transition: background var(--dur-2) var(--ease);
    }
    .hub-card:hover::before {
      background: var(--card-edge-hover);
    }
  }
  .hub-card::after {
    content: "";
    position: absolute;
    inset: -1px;
    z-index: -1;
    border-radius: inherit;
    box-shadow: 0 12px 50px var(--accent-glow);
    opacity: 0;
    transition: opacity var(--dur-3) var(--ease);
  }
  .hub-card:hover {
    transform: translateY(-2px);
  }
  .hub-card:hover::after {
    opacity: 0.6;
  }
  @media (prefers-reduced-motion: reduce) {
    .hub-card,
    .hub-card::after,
    .hub-card::before {
      transition: none;
    }
    .hub-card:hover {
      transform: none;
    }
  }
  .hub-card-head {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }
  .hub-ico {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--r-md);
    background: var(--accent-wash);
    border: 1px solid var(--border-accent);
    color: var(--accent-bright);
    flex: none;
  }
  .hub-card-head h2 {
    font-size: var(--h-card);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-head);
    line-height: 1.1;
    font-optical-sizing: auto;
  }
  .hub-blurb {
    position: relative;
    z-index: 2;
    color: var(--text-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-snug);
    margin-bottom: var(--sp-4);
  }
  .hub-links {
    position: relative;
    z-index: 4;
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .hub-links a {
    display: block;
    padding: 5px 8px;
    margin-inline: -8px;
    border-radius: var(--r-sm);
    color: var(--text-muted);
    font-size: var(--fs-sm);
    transition: color var(--dur-1), background var(--dur-1);
  }
  .hub-links a:hover {
    color: var(--accent-bright);
    background: var(--surface-2);
  }
</style>
