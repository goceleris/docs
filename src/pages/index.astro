---
import BaseLayout from "../layouts/BaseLayout.astro";
import CodeWindow from "../components/CodeWindow.astro";
import { heroStat, heroBars, fmtRpsShort, fmtMs, SITE_URL } from "../lib/site";

const stat = heroStat();
const bench = heroBars();
const maxRps = bench ? bench.bars[0].rps : 0;

// Latency view (back of the flip card): same frameworks, p99 latency, lower is
// better. Celeris is pinned first (it's at par with the fastest), then the rest
// ascending. Bar length is proportional to latency (lower = shorter bar).
const latRest = bench ? bench.bars.filter((b) => b.p99 != null && !b.isCeleris).sort((a, b) => (a.p99 as number) - (b.p99 as number)) : [];
const celLat = bench?.bars.find((b) => b.isCeleris && b.p99 != null) ?? null;
const latBars = celLat ? [celLat, ...latRest] : latRest;
const maxP99 = latBars.length ? Math.max(...latBars.map((b) => b.p99 as number)) : 0;
const celP99 = celLat?.p99 ?? null;
const hasLatency = latBars.length >= 3;

// Real anchors for the "net/http ceiling" chart (same scenario, get-simple-1024c).
const celBar = bench?.bars.find((b) => b.isCeleris) ?? null;
const netBar = bench?.bars.find((b) => /net\/http/i.test(b.name)) ?? null;
const showCeiling = !!(celBar && netBar);
const celLabel = celBar ? fmtRpsShort(celBar.rps) : "";
const netLabel = netBar ? fmtRpsShort(netBar.rps) : "";
const ratioLabel = celBar && netBar ? `+${Math.round((celBar.rps / netBar.rps - 1) * 100)}%` : "";

const helloCode = `package main

import (
    "log"
    "github.com/goceleris/celeris"
)

func main() {
    s := celeris.New(celeris.Config{Addr: ":8080"})
    s.GET("/hello", func(c *celeris.Context) error {
        return c.String(200, "Hello, World!")
    })
    log.Fatal(s.Start())
}`;

const apiCode = `s := celeris.New(celeris.Config{Addr: ":8080"})
s.Use(recovery.New(), logger.New())

api := s.Group("/api")
api.GET("/users/:id", func(c *celeris.Context) error {
    return c.JSON(200, store.Find(c.Param("id")))
})

// Blocking I/O? Move it off the event loop with .Async()
api.POST("/users", createUser).Async()`;

const engines = [
  {
    name: "io_uring",
    tag: "Linux 5.10+",
    body: "Completion-based async I/O with multishot accept/recv, provided buffer rings and zero-copy sendfile. The lowest-latency path on modern kernels.",
  },
  {
    name: "epoll",
    tag: "Linux 3.10+",
    body: "Edge-triggered, per-core event loops with CPU pinning. Proven, broad kernel support — and at throughput parity with io_uring.",
  },
  {
    name: "adaptive",
    tag: "default",
    body: "Runs both engines and switches at runtime on live telemetry. You get the best path for the box without choosing one.",
  },
];

const features = [
  { t: "Zero-allocation hot path", d: "Pooled contexts, pre-encoded HPACK, inline param & handler buffers. No interface boxing on the critical path.", icon: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>' },
  { t: "HTTP/1.1 + h2c", d: "RFC-9112 H1 and full HTTP/2 cleartext with stream multiplexing, flow control and a zero-alloc HEADERS fast path.", icon: '<path d="m16 3 4 4-4 4"/><path d="M20 7H4"/><path d="m8 21-4-4 4-4"/><path d="M4 17h16"/>' },
  { t: "SIMD parser", d: "SSE2 (amd64) and NEON (arm64) request parsing with a SWAR fallback — and smuggling / rapid-reset hardening built in.", icon: '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 2v2M15 2v2M9 20v2M15 20v2M2 9h2M2 15h2M20 9h2M20 15h2"/>' },
  { t: "Batteries-included middleware", d: "Auth, CORS, CSRF, rate-limit, circuit-breaker, compress, cache, metrics, OTel, WebSocket, SSE — production-ready, in-tree.", icon: '<path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/>' },
  { t: "Familiar API", d: "Route groups, hierarchical middleware, named routes and error-returning handlers. The Gin/Echo model you already know.", icon: '<path d="m16 18 6-6-6-6"/><path d="m8 6-6 6 6 6"/>' },
  { t: "Graceful everything", d: "Zero-downtime restart via socket inheritance, draining shutdown, load-shedding overload control and connection hooks.", icon: '<path d="M12 2v10"/><path d="M18.4 6.6a9 9 0 1 1-12.77.04"/>' },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    name: "Celeris",
    description: "High-performance Go HTTP engine with a dual-architecture (io_uring & epoll) for zero-allocation microservices.",
    codeRepository: "https://github.com/goceleris/celeris",
    programmingLanguage: "Go",
    license: "https://www.apache.org/licenses/LICENSE-2.0",
    url: SITE_URL,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Celeris",
    url: SITE_URL,
  },
];
---

<BaseLayout
  title="Celeris · High-performance Go HTTP engine"
  description="Celeris is a high-performance HTTP engine for Go with a protocol-aware dual-architecture (io_uring & epoll) built for high-throughput infrastructure and zero-allocation microservices."
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <a class="pill" href="/benchmarks">
          <span class="dot"></span>
          {stat ? <>Fastest Go framework in <b>{stat.goWinRate}</b> scenarios</> : <>Continuously benchmarked across frameworks</>}
          <svg class="arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>

        <h1>
          High-performance<br />HTTP for <span class="grad">Go</span>.
        </h1>
        <p class="lede">
          Celeris bypasses <code>net/http</code> with its own io_uring &amp; epoll event loop —
          a zero-allocation engine built for <strong>best-in-class throughput</strong> that stays fast
          and stays up under extreme, sustained load, with the routing and middleware API you already know.
        </p>
        <p class="hero-rotate" aria-label="Built for extreme throughput, sustained load, zero-alloc latency, and net/http drop-in">
          <span class="hr-pre">Built for</span>
          <span class="rotate" data-rotate="extreme throughput|sustained load|zero-alloc latency|net/http drop-in">extreme throughput</span><span class="caret" aria-hidden="true"></span>
        </p>

        <div class="cta">
          <a class="btn primary" href="/docs">Get started</a>
          <a class="btn ghost" href="/benchmarks">See the benchmarks</a>
        </div>
      </div>

      {bench && (
        <figure class="bench" aria-label={`Sustained requests per second: ${bench.bars.map((b) => `${b.name} ${b.rps.toLocaleString()}`).join(", ")}`}>
          {hasLatency && (
            <button type="button" class="bench-flip" data-bench-flip aria-pressed="false" aria-label="Flip to p99 latency">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2v6h-6" /><path d="M3 12a9 9 0 0 1 15-6.7L21 8" /><path d="M3 22v-6h6" /><path d="M21 12a9 9 0 0 1-15 6.7L3 16" /></svg>
            </button>
          )}
          <div class="bench-3d">
            <div class="bench-face bench-front">
              <figcaption class="bench-cap">
                <span class="bench-kicker">sustained req/s</span>
                <span class="bench-sub">across the frameworks you know</span>
              </figcaption>
              <div class="bench-bars">
                {bench.bars.map((b) => (
                  <div class:list={["bench-row", { win: b.isCeleris }]}>
                    <span class="bench-name"><span class="bn">{b.name}</span>{b.lang && <span class="bl">{b.lang}</span>}</span>
                    <span class="bench-track"><span class="bench-fill" style={`--w:${Math.max(2, Math.round((b.rps / maxRps) * 100))}%`}></span></span>
                    <span class="bench-val">{fmtRpsShort(b.rps)}</span>
                  </div>
                ))}
              </div>
              {stat && (
                <div class="bench-kpi">
                  <span class="kpi-n" data-countup data-to={stat.peakRps}>{fmtRpsShort(stat.peakRps)}</span>
                  <span class="kpi-l">peak req/s · {stat.version}</span>
                </div>
              )}
            </div>
            {hasLatency && (
              <div class="bench-face bench-back">
                <figcaption class="bench-cap">
                  <span class="bench-kicker">p99 latency</span>
                  <span class="bench-sub">lower is better · under full load</span>
                </figcaption>
                <div class="bench-bars">
                  {latBars.map((b) => (
                    <div class:list={["bench-row", { win: b.isCeleris }]}>
                      <span class="bench-name"><span class="bn">{b.name}</span>{b.lang && <span class="bl">{b.lang}</span>}</span>
                      <span class="bench-track"><span class="bench-fill" style={`--w:${Math.max(2, Math.round(((b.p99 as number) / maxP99) * 100))}%`}></span></span>
                      <span class="bench-val">{fmtMs(b.p99 as number)}</span>
                    </div>
                  ))}
                </div>
                {celP99 != null && (
                  <div class="bench-kpi">
                    <span class="kpi-n">{fmtMs(celP99)}</span>
                    <span class="kpi-l">Celeris p99 · {stat?.version}</span>
                  </div>
                )}
              </div>
            )}
          </div>
        </figure>
      )}
    </div>

    <div class="container hero-foot">
      <div class="stats">
        {stat ? (
          <>
            <div class="stat"><div class="n">{stat.goWinRate}</div><div class="l">fastest Go framework</div></div>
            {stat.goMaxMarginPct != null && (
              <div
                class="stat"
                title={`Up to +${stat.goMaxMarginPct}% higher throughput than the next-fastest full Go framework — on ${stat.goMaxMarginScenario}. Median lead across wins is +${stat.goWinMarginPct}%.`}
              >
                <div class="n"><span class="upto">up to</span>+{stat.goMaxMarginPct}%</div>
                <div class="l">vs next framework</div>
              </div>
            )}
            <div class="stat"><div class="n">0</div><div class="l">hot-path allocs</div></div>
            <div class="stat"><div class="n">{stat.totalAdapters}</div><div class="l">servers benchmarked</div></div>
          </>
        ) : (
          <>
            <div class="stat"><div class="n">io_uring</div><div class="l">+ epoll engines</div></div>
            <div class="stat"><div class="n">0</div><div class="l">hot-path allocs</div></div>
            <div class="stat"><div class="n">h2c</div><div class="l">+ HTTP/1.1</div></div>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- QUICKSTART -->
  <section class="container band">
    <div class="split reveal">
      <div>
        <span class="idx">quickstart</span>
        <h2>Hello, world — in the API you know.</h2>
        <p class="muted">
          A familiar Gin/Echo-style surface over an engine that does the hard part. Handlers
          return <code>error</code>; the rest is routing, groups and middleware.
        </p>
        <div class="install">
          <span class="prompt">$</span>
          <span class="install-cmd">go get github.com/goceleris/celeris@latest</span>
          <button class="install-copy" type="button" aria-label="Copy install command">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
          </button>
        </div>
        <ul class="ticks">
          <li>One import, one <code>Config</code> — no codegen, no build tags</li>
          <li>Runs the standard library's <code>http.Handler</code> too</li>
          <li>Linux gets io_uring/epoll; everything else gets a clean fallback</li>
        </ul>
      </div>
      <CodeWindow code={helloCode} file="main.go" />
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="container band center problem reveal">
    <h2>The <code>net/http</code> ceiling is real.</h2>
    <p class="muted statement">
      Go's standard server is excellent — until a flood of traffic hits a syscall and scheduler
      wall and throughput plateaus. Celeris replaces the I/O layer with a completion-driven event
      loop that pushes throughput far higher and holds it steady under sustained, extreme load —
      while your handler code stays untouched.
    </p>
    {showCeiling && (
      <figure
        class="cf"
        role="img"
        aria-label={`net/http plateaus at ${netLabel} req/s; Celeris keeps climbing to ${celLabel} req/s — ${ratioLabel} more headroom. Illustrative shape, real measured peaks at 1024 connections.`}
      >
        <svg class="cv" viewBox="0 0 500 220" aria-hidden="true">
          <defs>
            <linearGradient id="cvs" x1="0" y1="1" x2="1" y2="0">
              <stop offset="0" stop-color="var(--accent-dim)" />
              <stop offset="1" stop-color="var(--accent-bright)" />
            </linearGradient>
            <linearGradient id="cva" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="var(--accent)" stop-opacity="0.2" />
              <stop offset="1" stop-color="var(--accent)" stop-opacity="0" />
            </linearGradient>
          </defs>
          <g class="g">
            <line x1="60" y1="40" x2="460" y2="40" />
            <line x1="60" y1="110" x2="460" y2="110" />
            <line x1="60" y1="180" x2="460" y2="180" />
          </g>
          <g class="y">
            <text x="52" y="43">1.4M</text>
            <text x="52" y="113">700k</text>
            <text x="52" y="183">0</text>
          </g>
          <path class="ax" d="M60,34V180H464" />
          <text class="xl" x="460" y="198" text-anchor="end">offered load →</text>
          <path class="bd" d="M150,118C260,116 340,96 460,40L460,118Z" />
          <line class="ce" x1="150" y1="118" x2="460" y2="118" />
          <text class="cl" x="300" y="136" text-anchor="middle">net/http ceiling</text>
          <path class="fl" d="M60,154C110,140 150,118 150,118 260,116 340,96 460,40L460,180 60,180Z" />
          <path class="nt" d="M60,154C110,140 150,118 150,118 260,119 360,118 460,118" />
          <path class="ln" d="M60,154C110,140 150,118 150,118 260,116 340,96 460,40" />
          <text class="tn" x="348" y="108" text-anchor="middle">{ratioLabel}</text>
          <circle class="dn" cx="460" cy="118" r="3.5" />
          <text class="vn" x="454" y="132" text-anchor="end">{netLabel}</text>
          <circle class="dc" cx="460" cy="40" r="4" />
          <text class="vc" x="454" y="33" text-anchor="end">{celLabel}</text>
        </svg>
        <figcaption class="cf-legend">
          <span><i class="sw rival"></i> net/http — plateaus</span>
          <span><i class="sw cel"></i> Celeris — climbs past it</span>
        </figcaption>
      </figure>
    )}
  </section>

  <!-- ENGINES -->
  <section class="container band">
    <div class="sec-head reveal">
      <span class="idx">01 · engines</span>
      <h2>Three engines. One port.</h2>
      <p class="lede-sm">Pick a path — or let Celeris pick for you, live. Any protocol runs on any engine.</p>
    </div>
    <div class="cards engines reveal-stagger">
      {engines.map((e) => (
        <article class:list={["card", "engine", { feature: e.tag === "default" }]}>
          <header>
            <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 6l5 6-5 6M12 6l5 6-5 6" /></svg>
            <h3>{e.name}</h3>
            <span class="tag">{e.tag}</span>
          </header>
          <p>{e.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- FEATURES -->
  <section class="container band">
    <div class="sec-head reveal">
      <span class="idx">02 · what you get</span>
      <h2>Built for production, not just throughput.</h2>
    </div>
    <div class="cards features reveal-stagger">
      {features.map((f) => (
        <article class="card feat">
          <span class="feat-ico"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={f.icon} /></span>
          <h3>{f.t}</h3>
          <p>{f.d}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- API EXAMPLE -->
  <section class="container band">
    <div class="split reverse reveal">
      <CodeWindow code={apiCode} file="routes.go" />
      <div>
        <span class="idx">03 · ergonomics</span>
        <h2>Route, group, compose.</h2>
        <p class="muted">
          Hierarchical middleware, named routes, content negotiation and per-route async
          dispatch — choose inline-on-worker for CPU/cache routes, or a goroutine for blocking I/O.
        </p>
        <ul class="ticks">
          <li>Static, <code>:param</code> and <code>*wildcard</code> routes</li>
          <li>Structured <code>HTTPError</code> + recovery</li>
          <li>Streaming, SSE, WebSocket &amp; hijacking</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- VALIDATION / BENCHMARKS -->
  <section class="container band">
    <div class="validate reveal">
      <div>
        <span class="idx">04 · benchmarked &amp; validated</span>
        <h2>Numbers you can re-run.</h2>
        <p class="muted">
          <a href="https://github.com/goceleris/probatorium" target="_blank" rel="noopener">probatorium</a>
          benchmarks Celeris on a dedicated cluster — weekly and on demand — against a broad field of
          frameworks and scenarios; browse every result here, averaged across runs. Separately, nightly
          and weekend-soak validation hammers it with realistic traffic, fuzzing and connection &amp;
          WebSocket torture.
        </p>
        <a class="btn primary" href="/benchmarks">Open the dashboard →</a>
      </div>
      <div class="validate-stat">
        {stat ? (
          <>
            <div class="big">{fmtRpsShort(stat.peakRps)}</div>
            <div class="muted">peak req/s · {stat.version} · averaged over all runs</div>
          </>
        ) : (
          <>
            <div class="big">live</div>
            <div class="muted">results publish here after each cluster run</div>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="container band center final">
    <h2>Make Go fast where it counts.</h2>
    <div class="cta">
      <a class="btn primary" href="/docs">Read the docs</a>
      <a class="btn ghost" href="https://github.com/goceleris/celeris" target="_blank" rel="noopener">Star on GitHub</a>
    </div>
  </section>

  {/* Count-up for the hero KPI — sub-1KB, reduced-motion aware, final value on reduce. */}
  <script is:inline>
    (function () {
      var el = document.querySelector("[data-countup]");
      if (!el) return;
      function fmt(n) {
        if (n >= 1e6) return (n / 1e6).toFixed(2) + "M";
        if (n >= 1e3) return Math.round(n / 1e3) + "k";
        return "" + Math.round(n);
      }
      var to = parseFloat(el.getAttribute("data-to") || "0");
      if (!to || (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches)) return;
      function run() {
        var start = Math.round(to * 0.4), dur = 900, t0 = 0;
        function step(ts) {
          if (!t0) t0 = ts;
          var p = Math.min(1, (ts - t0) / dur);
          var eased = 1 - Math.pow(1 - p, 3);
          el.textContent = fmt(start + (to - start) * eased);
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = fmt(to);
        }
        requestAnimationFrame(step);
      }
      if ("IntersectionObserver" in window) {
        var io = new IntersectionObserver(function (es) {
          es.forEach(function (e) { if (e.isIntersecting) { run(); io.disconnect(); } });
        }, { threshold: 0.4 });
        io.observe(el);
      } else { run(); }
    })();
  </script>

  {/* Install command copy — mirrors the code-block copy button. */}
  <script is:inline>
    (function () {
      var btn = document.querySelector(".install-copy");
      var cmd = document.querySelector(".install-cmd");
      if (!btn || !cmd) return;
      var COPY = btn.innerHTML;
      var DONE = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>';
      function flash() {
        btn.innerHTML = DONE; btn.classList.add("done");
        setTimeout(function () { btn.innerHTML = COPY; btn.classList.remove("done"); }, 1200);
      }
      function fallback(text) {
        try {
          var ta = document.createElement("textarea");
          ta.value = text; ta.style.position = "fixed"; ta.style.opacity = "0";
          document.body.appendChild(ta); ta.select(); document.execCommand("copy");
          document.body.removeChild(ta); flash();
        } catch (e) {}
      }
      btn.addEventListener("click", function () {
        var text = cmd.textContent.trim();
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(flash, function () { fallback(text); });
        } else {
          fallback(text);
        }
      });
    })();
  </script>

  {/* Hero typed rotator — adds life without touching the static H1 (SEO/LCP safe).
      Reduced-motion shows the first phrase, no caret. */}
  <script is:inline>
    (function () {
      var el = document.querySelector("[data-rotate]");
      if (!el) return;
      var words = (el.getAttribute("data-rotate") || "").split("|").filter(Boolean);
      if (words.length < 2) return;
      if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      el.classList.add("typing");
      var i = 0, ch = 0, deleting = false;
      function tick() {
        var w = words[i];
        ch += deleting ? -1 : 1;
        el.textContent = w.slice(0, ch);
        var delay = deleting ? 45 : 80;
        if (!deleting && ch === w.length) { delay = 1500; deleting = true; }
        else if (deleting && ch === 0) { deleting = false; i = (i + 1) % words.length; delay = 350; }
        setTimeout(tick, delay);
      }
      setTimeout(tick, 1200);
    })();
  </script>

  {/* Bench flip card: toggle throughput <-> p99 latency. */}
  <script is:inline>
    (function () {
      var fig = document.querySelector(".bench");
      var btn = document.querySelector("[data-bench-flip]");
      if (!fig || !btn) return;
      btn.addEventListener("click", function () {
        var flipped = fig.classList.toggle("flipped");
        btn.setAttribute("aria-pressed", String(flipped));
        btn.setAttribute("aria-label", flipped ? "Flip to throughput" : "Flip to p99 latency");
      });
    })();
  </script>

  {/* Ceiling chart: draw in when scrolled into view (static final state without JS / reduced-motion). */}
  <script is:inline>
    (function () {
      var cf = document.querySelector(".cf");
      if (!cf) return;
      cf.classList.add("anim");
      if ("IntersectionObserver" in window) {
