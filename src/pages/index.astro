---
import { Code } from "astro:components";
import BaseLayout from "../layouts/BaseLayout.astro";
import { heroStat, fmtRpsShort, SITE_URL } from "../lib/site";

const stat = heroStat();

const helloCode = `package main

import (
    "log"
    "github.com/goceleris/celeris"
)

func main() {
    s := celeris.New(celeris.Config{Addr: ":8080"})
    s.GET("/hello", func(c *celeris.Context) error {
        return c.String(200, "Hello, World!")
    })
    log.Fatal(s.Start())
}`;

const apiCode = `s := celeris.New(celeris.Config{Addr: ":8080"})
s.Use(recovery.New(), logger.New())

api := s.Group("/api")
api.GET("/users/:id", func(c *celeris.Context) error {
    return c.JSON(200, store.Find(c.Param("id")))
})

// Blocking I/O? Move it off the event loop with .Async()
api.POST("/users", createUser).Async()`;

const engines = [
  {
    name: "io_uring",
    tag: "Linux 5.10+",
    body: "Completion-based async I/O with multishot accept/recv, provided buffer rings and zero-copy sendfile. The lowest-latency path on modern kernels.",
  },
  {
    name: "epoll",
    tag: "Linux 3.10+",
    body: "Edge-triggered, per-core event loops with CPU pinning. Proven, broad kernel support — and at throughput parity with io_uring.",
  },
  {
    name: "adaptive",
    tag: "default",
    body: "Runs both engines and switches at runtime on live telemetry. You get the best path for the box without choosing one.",
  },
];

const features = [
  { t: "Zero-allocation hot path", d: "Pooled contexts, pre-encoded HPACK, inline param & handler buffers. No interface boxing on the critical path." },
  { t: "HTTP/1.1 + h2c", d: "RFC-9112 H1 and full HTTP/2 cleartext with stream multiplexing, flow control and a zero-alloc HEADERS fast path." },
  { t: "SIMD parser", d: "SSE2 (amd64) and NEON (arm64) request parsing with a SWAR fallback — and smuggling / rapid-reset hardening built in." },
  { t: "Batteries-included middleware", d: "Auth, CORS, CSRF, rate-limit, circuit-breaker, compress, cache, metrics, OTel, WebSocket, SSE — production-ready, in-tree." },
  { t: "Familiar API", d: "Route groups, hierarchical middleware, named routes and error-returning handlers. The Gin/Echo model you already know." },
  { t: "Graceful everything", d: "Zero-downtime restart via socket inheritance, draining shutdown, load-shedding overload control and connection hooks." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    name: "Celeris",
    description: "High-performance Go HTTP engine with a dual-architecture (io_uring & epoll) for zero-allocation microservices.",
    codeRepository: "https://github.com/goceleris/celeris",
    programmingLanguage: "Go",
    license: "https://www.apache.org/licenses/LICENSE-2.0",
    url: SITE_URL,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Celeris",
    url: SITE_URL,
  },
];
---

<BaseLayout
  title="Celeris · High-performance Go HTTP engine"
  description="Celeris is a high-performance HTTP engine for Go with a protocol-aware dual-architecture (io_uring & epoll) built for high-throughput infrastructure and zero-allocation microservices."
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="streaks" aria-hidden="true"></div>
    <div class="container hero-inner">
      <a class="pill" href="/benchmarks">
        <span class="dot"></span>
        {stat ? <>Fastest Go framework in <b>{stat.goWinRate}</b> scenarios</> : <>Continuously benchmarked across frameworks</>}
        <svg class="arr" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>

      <h1>
        High-performance<br />HTTP for <span class="grad">Go</span>.
      </h1>
      <p class="lede">
        Celeris bypasses <code>net/http</code> with its own io_uring &amp; epoll event loop —
        a zero-allocation engine built for <strong>best-in-class throughput</strong> that stays fast
        and stays up under extreme, sustained load, with the routing and middleware API you already know.
      </p>

      <p class="matrix-note">
        <span class="mx">protocol × engine</span> — any protocol on any engine, extensible to both.
      </p>

      <div class="cta">
        <a class="btn primary" href="/docs">Get started</a>
        <a class="btn ghost" href="/benchmarks">See the benchmarks</a>
      </div>

      <div class="stats">
        {stat ? (
          <>
            <div class="stat"><div class="n">{fmtRpsShort(stat.peakRps)}</div><div class="l">peak req/s</div></div>
            <div class="stat" title="Scenarios where Celeris has the highest throughput of all full Go web frameworks (gin, echo, fiber, chi, iris, hertz)">
              <div class="n">{stat.goWinRate}</div><div class="l">fastest Go framework</div>
            </div>
            {stat.goMaxMarginPct != null && (
              <div
                class="stat"
                title={`Up to +${stat.goMaxMarginPct}% higher throughput than the next-fastest full Go framework (gin, echo, fiber, chi, iris, hertz) — on ${stat.goMaxMarginScenario}. Median lead across wins is +${stat.goWinMarginPct}%.`}
              >
                <div class="n"><span class="upto">up to</span>+{stat.goMaxMarginPct}%</div>
                <div class="l">vs next framework</div>
              </div>
            )}
            <div class="stat"><div class="n">0</div><div class="l">hot-path allocs</div></div>
          </>
        ) : (
          <>
            <div class="stat"><div class="n">io_uring</div><div class="l">+ epoll engines</div></div>
            <div class="stat"><div class="n">0</div><div class="l">hot-path allocs</div></div>
            <div class="stat"><div class="n">h2c</div><div class="l">+ HTTP/1.1</div></div>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- QUICKSTART -->
  <section class="container band">
    <div class="split">
      <div>
        <h2>Hello, world — in the API you know.</h2>
        <p class="muted">
          A familiar Gin/Echo-style surface over an engine that does the hard part. Handlers
          return <code>error</code>; the rest is routing, groups and middleware.
        </p>
        <div class="install">
          <span class="prompt">$</span> go get github.com/goceleris/celeris@latest
        </div>
      </div>
      <div class="code-card">
        <Code code={helloCode} lang="go" theme="github-dark-default" />
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="container band center">
    <h2>The <code>net/http</code> ceiling is real.</h2>
    <p class="muted narrow">
      Go's standard server is excellent — until a flood of traffic hits a syscall and scheduler
      wall and throughput plateaus. Celeris replaces the I/O layer with a completion-driven event
      loop that pushes throughput far higher and holds it steady under sustained, extreme load —
      while your handler code stays untouched.
    </p>
  </section>

  <!-- ENGINES -->
  <section class="container band">
    <div class="sec-head">
      <h2>Three engines. One port.</h2>
      <p class="muted">Pick a path — or let Celeris pick for you, live.</p>
    </div>
    <div class="cards three">
      {engines.map((e) => (
        <article class="card engine">
          <header><span class="chev" aria-hidden="true">›››</span><h3>{e.name}</h3><span class="tag">{e.tag}</span></header>
          <p>{e.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- FEATURES -->
  <section class="container band">
    <div class="sec-head">
      <h2>Built for production, not just throughput.</h2>
    </div>
    <div class="cards two">
      {features.map((f) => (
        <article class="card feat">
          <h3>{f.t}</h3>
          <p>{f.d}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- API EXAMPLE -->
  <section class="container band">
    <div class="split reverse">
      <div class="code-card">
        <Code code={apiCode} lang="go" theme="github-dark-default" />
      </div>
      <div>
        <h2>Route, group, compose.</h2>
        <p class="muted">
          Hierarchical middleware, named routes, content negotiation and per-route async
          dispatch — choose inline-on-worker for CPU/cache routes, or a goroutine for blocking I/O.
        </p>
        <ul class="ticks">
          <li>Static, <code>:param</code> and <code>*wildcard</code> routes</li>
          <li>Structured <code>HTTPError</code> + recovery</li>
          <li>Streaming, SSE, WebSocket &amp; hijacking</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- VALIDATION / BENCHMARKS -->
  <section class="container band">
    <div class="validate">
      <div>
        <span class="kicker">Benchmarked &amp; validated</span>
        <h2>Numbers you can re-run.</h2>
        <p class="muted">
          <a href="https://github.com/goceleris/probatorium" target="_blank" rel="noopener">probatorium</a>
          benchmarks Celeris on a dedicated cluster — weekly and on demand — against a broad field of
          frameworks and scenarios; browse every result here, averaged across runs. Separately, nightly
          and weekend-soak validation hammers it with realistic traffic, fuzzing and connection &amp;
          WebSocket torture.
        </p>
        <a class="btn primary" href="/benchmarks">Open the dashboard →</a>
      </div>
      <div class="validate-stat">
        {stat ? (
          <>
            <div class="big">{fmtRpsShort(stat.peakRps)}</div>
            <div class="muted">peak req/s · {stat.version} · averaged over all runs</div>
          </>
        ) : (
          <>
            <div class="big">live</div>
            <div class="muted">results publish here after each cluster run</div>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="container band center final">
    <h2>Make Go fast where it counts.</h2>
    <div class="cta">
      <a class="btn primary" href="/docs">Read the docs</a>
      <a class="btn ghost" href="https://github.com/goceleris/celeris" target="_blank" rel="noopener">Star on GitHub</a>
    </div>
  </section>
</BaseLayout>

<style>
  .muted { color: var(--text-muted); }
  .narrow { max-width: 52ch; margin-inline: auto; }
  code { color: var(--accent-bright); background: var(--accent-wash); padding: 0.1em 0.35em; border-radius: 4px; }

  /* HERO */
  .hero { position: relative; overflow: hidden; padding-block: clamp(4rem, 12vw, 9rem) clamp(3rem, 7vw, 6rem); border-bottom: 1px solid var(--border); }
  .hero-glow {
    position: absolute; inset: -40% 0 auto 0; height: 80%;
    background: radial-gradient(60% 60% at 50% 0%, var(--accent-glow), transparent 70%);
    pointer-events: none; filter: blur(8px);
  }
  .streaks {
    position: absolute; inset: 0; pointer-events: none; opacity: 0.5;
    background-image: repeating-linear-gradient(115deg, transparent 0 38px, color-mix(in oklch, var(--accent) 22%, transparent) 38px 39px);
    -webkit-mask-image: radial-gradient(120% 90% at 80% 0%, black, transparent 60%);
    mask-image: radial-gradient(120% 90% at 80% 0%, black, transparent 60%);
    animation: drift 16s linear infinite;
  }
  @keyframes drift { to { background-position: 240px 0; } }
  @media (prefers-reduced-motion: reduce) { .streaks { animation: none; } }
  .hero-inner { position: relative; }
  .hero h1 { font-size: var(--fs-3xl); letter-spacing: -0.04em; margin-bottom: var(--sp-4); }
  .grad {
    background: linear-gradient(100deg, var(--accent-bright), var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    /* background-clip:text + negative letter-spacing clips the last glyph's edge;
       pad the clip box and offset so the trailing "." stays snug. */
    padding-right: 0.1em;
    margin-right: -0.08em;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }
  .lede { font-size: clamp(1.05rem, 2.2vw, 1.35rem); color: var(--text-muted); max-width: 58ch; line-height: var(--lh-snug); }
  .lede strong { color: var(--text); font-weight: var(--fw-semibold); }
  .matrix-note { margin-top: var(--sp-4); font-size: var(--fs-sm); color: var(--text-muted); }
  .matrix-note .mx {
    color: var(--accent-bright);
    font-weight: var(--fw-semibold);
    font-family: var(--font-mono);
    letter-spacing: -0.01em;
    padding: 2px 7px;
    margin-right: 4px;
    border: 1px solid var(--border-accent);
    border-radius: var(--r-full);
    background: var(--accent-wash);
    white-space: nowrap;
  }

  .pill {
    display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: var(--sp-5);
    padding: 0.4rem 0.85rem; border: 1px solid var(--border-strong); border-radius: var(--r-full);
    font-size: var(--fs-2xs); color: var(--text-muted); transition: border-color var(--dur-1), color var(--dur-1);
  }
  .pill:hover { border-color: var(--border-accent); color: var(--text); }
  .pill b { color: var(--accent-bright); }
  .pill .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); }
  .pill .arr { color: var(--accent); }

  .cta { display: flex; gap: var(--sp-3); flex-wrap: wrap; margin-top: var(--sp-6); }
  .btn { display: inline-flex; align-items: center; padding: 0.7rem 1.3rem; border-radius: var(--r-md); font-weight: var(--fw-semibold); font-size: var(--fs-sm); transition: transform var(--dur-1), box-shadow var(--dur-1), background var(--dur-1); }
  .btn.primary { background: var(--accent); color: var(--text-on-accent); box-shadow: 0 8px 24px var(--accent-glow); }
  .btn.primary:hover { transform: translateY(-1px); box-shadow: 0 12px 30px var(--accent-glow); }
  .btn.ghost { border: 1px solid var(--border-strong); color: var(--text); }
  .btn.ghost:hover { border-color: var(--accent); color: var(--accent-bright); }

  .stats { display: flex; gap: clamp(1.5rem, 5vw, 3.5rem); margin-top: var(--sp-7); flex-wrap: wrap; }
  .stat .n { font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: var(--fw-bold); color: var(--accent-bright); font-variant-numeric: tabular-nums; letter-spacing: -0.03em; }
  .stat .n .upto { font-size: 0.5em; font-weight: var(--fw-medium); color: var(--text-faint); letter-spacing: 0; margin-right: 0.35em; vertical-align: 0.25em; text-transform: uppercase; }
  .stat .l { font-size: var(--fs-2xs); color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.08em; }

  /* BANDS */
  .band { padding-block: clamp(3rem, 7vw, 5.5rem); }
  .band.center { text-align: center; }
  .band.center .cta { justify-content: center; }
  .band h2 { font-size: clamp(1.6rem, 3.5vw, 2.4rem); letter-spacing: -0.03em; margin-bottom: var(--sp-3); }
  .sec-head { margin-bottom: var(--sp-6); }

  .split { display: grid; grid-template-columns: 1fr 1.05fr; gap: clamp(1.5rem, 4vw, 3.5rem); align-items: center; }
  .split.reverse { grid-template-columns: 1.05fr 1fr; }
  .code-card { border: 1px solid var(--border); border-radius: var(--r-lg); overflow: hidden; box-shadow: var(--shadow-2); }
  .code-card :global(pre) { margin: 0; border: none; border-radius: 0; padding: var(--sp-5); }

  .install { margin-top: var(--sp-5); padding: 0.85rem 1.1rem; border: 1px solid var(--border); border-radius: var(--r-md); background: var(--surface-1); font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--text); }
  .install .prompt { color: var(--accent); margin-right: 0.6rem; user-select: none; }

  .cards { display: grid; gap: var(--sp-4); }
  .cards.three { grid-template-columns: repeat(3, 1fr); }
  .cards.two { grid-template-columns: repeat(3, 1fr); }
  .card { border: 1px solid var(--border); border-radius: var(--r-lg); padding: var(--sp-5); background: var(--surface-1); transition: border-color var(--dur-2), transform var(--dur-2); }
  .card:hover { border-color: var(--border-accent); transform: translateY(-2px); }
  .card h3 { font-size: var(--fs-md); margin-bottom: var(--sp-2); }
  .card p { color: var(--text-muted); font-size: var(--fs-sm); }
  .card.engine header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: var(--sp-3); }
  .card.engine h3 { margin: 0; font-family: var(--font-mono); color: var(--accent-bright); }
  .card.engine .chev { color: var(--accent); letter-spacing: -2px; opacity: 0.8; }
  .card.engine .tag { margin-left: auto; font-size: var(--fs-3xs); color: var(--text-faint); border: 1px solid var(--border); border-radius: var(--r-full); padding: 1px 8px; }

  .ticks { list-style: none; padding: 0; margin-top: var(--sp-4); display: flex; flex-direction: column; gap: var(--sp-2); }
  .ticks li { padding-left: 1.5rem; position: relative; color: var(--text-muted); }
  .ticks li::before { content: "›››"; position: absolute; left: 0; color: var(--accent); letter-spacing: -2px; font-size: 0.8em; }

  .validate { display: grid; grid-template-columns: 1.5fr 1fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; border: 1px solid var(--border-accent); border-radius: var(--r-lg); padding: clamp(1.5rem, 4vw, 3rem); background: linear-gradient(120deg, var(--accent-wash), transparent); }
  .kicker { font-size: var(--fs-2xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); }
  .validate p a { color: var(--accent-bright); text-decoration: underline; text-underline-offset: 2px; }
  .validate .btn { margin-top: var(--sp-4); }
  .validate-stat { text-align: right; }
  .validate-stat .big { font-size: clamp(2.4rem, 6vw, 4rem); font-weight: var(--fw-bold); color: var(--accent-bright); letter-spacing: -0.04em; line-height: 1; }

  .final h2 { margin-bottom: var(--sp-5); }

  @media (max-width: 820px) {
    .split, .split.reverse, .validate { grid-template-columns: 1fr; }
    .cards.three, .cards.two { grid-template-columns: 1fr; }
    .validate-stat { text-align: left; }
  }
</style>
